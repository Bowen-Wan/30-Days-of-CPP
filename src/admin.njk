---
layout: layouts/base.njk
title: Admin — 30-Day C++ Sprint
eleventyExcludeFromCollections: true
---

{% include "components/hero.njk" %}

<main class="main">
  <section class="section admin-panel">
    <h1>Admin Panel</h1>
    <p>Update the current day. This commits to <code>src/_data/curriculum.json</code> and triggers a rebuild.</p>
    
    <form class="admin-form" id="adminForm">
      <label>
        <span>Current Day (1–30)</span>
        <select name="currentDay" id="currentDaySelect" required>
          {% for i in range(1, 31) %}
          <option value="{{ i }}" {% if i == curriculum.currentDay %}selected{% endif %}>Day {{ i }}</option>
          {% endfor %}
        </select>
      </label>
      
      <div class="admin-actions">
        <button type="submit" class="btn btn--primary" id="submitBtn">Save & Deploy</button>
        <a href="/" class="btn btn--secondary">Cancel</a>
      </div>
      
      <p id="statusMsg" style="margin-top: 1rem; min-height: 1.5em;"></p>
    </form>
  </section>
</main>

{% include "components/footer.njk" %}

<script type="module">
  const form = document.getElementById('adminForm');
  const select = document.getElementById('currentDaySelect');
  const btn = document.getElementById('submitBtn');
  const status = document.getElementById('statusMsg');
  
  // Get session from URL
  const urlParams = new URLSearchParams(window.location.search);
  const session = urlParams.get('session');
  
  if (!session) {
    status.textContent = 'No admin session. Please log in via GitHub OAuth.';
    status.style.color = 'var(--err)';
    btn.disabled = true;
  }
  
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (!session) return;
    
    btn.disabled = true;
    btn.textContent = 'Deploying...';
    status.textContent = '';
    
    try {
      const response = await fetch('/api/admin/update-day', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${session}`
        },
        body: JSON.stringify({ currentDay: parseInt(select.value, 10) })
      });
      
      const data = await response.json();
      
      if (response.ok) {
        status.textContent = `✓ Updated to Day ${data.currentDay}. GitHub Actions rebuild triggered. Live in ~60s.`;
        status.style.color = 'var(--ok)';
      } else {
        throw new Error(data.error || 'Unknown error');
      }
    } catch (err) {
      status.textContent = `✗ Failed: ${err.message}`;
      status.style.color = 'var(--err)';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Save & Deploy';
    }
  });
</script>