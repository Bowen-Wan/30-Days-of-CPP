<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} — {% endif %}30-Day C++ Sprint</title>
  <meta name="description" content="A 30-day project-based C++ curriculum for VEX robotics preparation. Retrieval-test structure, honest commit log, no marketing fluff.">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="{{ baseUrl }}assets/fonts/IBMPlexMono-Regular.woff2">
  <link rel="stylesheet" href="{{ baseUrl }}assets/css/styles.css">
  {% block head %}{% endblock %}
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  
  {% include "components/hero.njk" %}
  
  <main id="main" class="main">
    {% block content %}{% endblock %}
  </main>
  
  {% include "components/slide-panel.njk" %}
  
  <script type="module">
    import { init } from '{{ baseUrl }}assets/js/app.js';
    init();
  </script>
</body>
</html>