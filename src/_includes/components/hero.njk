<header class="hero" role="banner">
  <div class="hero-left">
    <span class="hero-title">30-Day C++ Sprint</span>
    <a href="https://github.com/Bowen-Wan/30-Days-of-CPP" target="_blank" rel="noopener" class="btn btn--ghost btn--sm" aria-label="View on GitHub">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      <span>Repository</span>
    </a>
  </div>
  
  <div class="hero-center">
    <span class="hero-badge" id="currentDayBadge">Day {{ curriculum.currentDay }} of 30</span>
  </div>
  
  <div class="hero-right">
    <div class="progress-bar progress-bar--mini" id="heroProgressBar" role="progressbar" aria-valuenow="{{ curriculum.currentDay }}" aria-valuemin="1" aria-valuemax="30" aria-label="Overall progress"></div>
    <div id="auth-controls" style="display:flex;align-items:center;gap:8px;margin-left:12px;">
      <!-- Google Sign-In button will be rendered here -->
      <div id="gsi-btn"></div>
      <span id="user-info" style="display:none;font-size:0.75rem;color:var(--fg-muted);"></span>
    </div>
  </div>
</header>