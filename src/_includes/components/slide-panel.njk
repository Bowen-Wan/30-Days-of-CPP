<aside class="slide-panel" id="slidePanel" role="dialog" aria-modal="true" aria-labelledby="slidePanelTitle" hidden>
  <header class="slide-panel-header">
    <h2 class="slide-panel-title" id="slidePanelTitle">Day Detail</h2>
    <button class="slide-panel-close" id="slidePanelClose" aria-label="Close panel">&times;</button>
  </header>
  <div class="slide-panel-body" id="slidePanelBody">
    <div class="day-detail-placeholder">Click a day row to view details</div>
  </div>
  <footer class="slide-panel-footer">
    <button class="btn btn--secondary" id="slidePanelPrev" disabled>← Previous</button>
    <button class="btn btn--primary" id="slidePanelNext" disabled>Next →</button>
    <button class="btn btn--primary" id="slidePanelMarkComplete">Mark Complete</button>
  </footer>
</aside>
<div class="slide-panel-overlay" id="slidePanelOverlay" hidden></div>