<section class="section curriculum-cards-section" aria-labelledby="curriculum-title-mobile" hidden>
  <header class="section-header">
    <h2 class="section-title" id="curriculum-title-mobile">Daily Curriculum</h2>
    <div class="progress-bar" id="sectionProgressBarMobile" role="progressbar" aria-valuenow="{{ curriculum.currentDay }}" aria-valuemin="0" aria-valuemax="30" aria-label="Curriculum progress">
      {% for i in range(1, 31) %}
        <span class="progress-segment {% if i <= curriculum.currentDay - 1 %}progress-segment--done{% elif i == curriculum.currentDay %}progress-segment--current{% else %}progress-segment--pending{% endif %}" title="Day {{ i }}: {{ curriculum.days[i-1].project }}"></span>
      {% endfor %}
    </div>
    <p class="progress-label">{{ curriculum.currentDay - 1 }} complete · Day {{ curriculum.currentDay }} current · {{ 30 - curriculum.currentDay }} remaining</p>
  </header>
  
  <div class="curriculum-cards" id="curriculumCards">
    {% for day in curriculum.days %}
    <details class="curriculum-card" data-day="{{ day.day }}" data-status="{{ day.status }}">
      <summary class="card-header">
        <span class="card-day">Day {{ day.day }}</span>
        <h3 class="card-project">{{ day.project }}</h3>
        <span class="status-badge status-badge--{{ day.status }}" aria-label="{{ day.status | statusLabel }}">
          {{ day.status | statusIcon }}
        </span>
      </summary>
      <div class="card-content" id="card-content-{{ day.day }}">
        <div class="day-detail-meta">
          <span class="badge badge--{{ day.status }}">{{ day.status | statusLabel }}</span>
          {% if day.commit %}
          <a href="https://github.com/Bowen-Wan/30-Days-of-CPP/commit/{{ day.commit }}" target="_blank" rel="noopener" class="day-detail-commit">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
            View commit
          </a>
          {% endif %}
        </div>
        <section class="day-detail-section">
          <h4>Core Concept</h4>
          <p>{{ day.concept }}</p>
        </section>
        {% if day.description %}
        <section class="day-detail-section">
          <h4>Description</h4>
          <p>{{ day.description }}</p>
        </section>
        {% endif %}
        {% if day.requirements %}
        <section class="day-detail-section">
          <h4>Requirements</h4>
          <ul class="day-detail-requirements">
            {% for req in day.requirements %}
            <li>
              <input type="checkbox" id="req-{{ day.day }}-{{ loop.index }}" data-day="{{ day.day }}" data-req-index="{{ loop.index0 }}">
              <label for="req-{{ day.day }}-{{ loop.index }}">{{ req }}</label>
            </li>
            {% endfor %}
          </ul>
        </section>
        {% endif %}
        {% if day.extraChallenge %}
        <section class="day-detail-section">
          <h4>Extra Challenge</h4>
          <p>{{ day.extraChallenge }}</p>
        </section>
        {% endif %}
        <div class="day-detail-actions">
          <button class="btn btn--secondary btn--sm mark-complete-btn" data-day="{{ day.day }}" {% if day.status === 'done' %}disabled{% endif %}>
            {% if day.status === 'done' %}✓ Marked Complete{% else %}Mark Complete{% endif %}
          </button>
        </div>
      </div>
    </details>
    {% endfor %}
  </div>
</section>